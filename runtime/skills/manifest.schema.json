{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "APEX RuntimeOS Skill Manifest",
  "type": "object",
  "required": ["id", "version", "description", "entry", "status", "required_scopes", "provenance", "checksum", "tests"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"},
    "version": {"type": "string"},
    "description": {"type": "string", "minLength": 1},
    "entry": {"type": "string"},
    "status": {"type": "string", "enum": ["reference_only", "candidate", "sandboxed", "trusted", "deprecated"]},
    "capability_tags": {"type": "array", "items": {"type": "string"}},
    "required_scopes": {
      "type": "array",
      "items": {"type": "string", "enum": ["file_read", "file_write", "network", "shell", "browser", "llm_call", "memory_write", "external_publish"]}
    },
    "sandbox_profile": {"type": "string"},
    "provenance": {
      "type": "object",
      "required": ["source", "source_hash"],
      "properties": {
        "source": {"type": "string"},
        "source_hash": {"type": "string"},
        "license": {"type": "string"},
        "reviewer": {"type": "string"}
      },
      "additionalProperties": false
    },
    "checksum": {"type": "string"},
    "tests": {"type": "array", "items": {"type": "string"}},
    "rollback": {"type": "string"}
  },
  "additionalProperties": false
}
